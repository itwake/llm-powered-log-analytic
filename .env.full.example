# =============================================================================
# LogAn environment reference - every supported variable with its default.
#
# For local development you normally want the minimal .env.example instead.
# This file is also copy-safe: the active values below match the minimal
# quick-start configuration, and everything optional is commented out with
# its default or an example value.
#
# The API reads process environment variables only; it does not parse .env
# itself. Load it with scripts\dev.ps1 (Windows) or
# `set -a; source .env; set +a` (macOS/Linux). Docker Compose reads .env
# automatically for ${VAR} interpolation defaults.
# =============================================================================

# -----------------------------------------------------------------------------
# Core runtime.
# LOGAN_ENV=production enforces strong secrets, TLS verification, and
# disables mock SSO at startup.
# -----------------------------------------------------------------------------
LOGAN_ENV=development
LOGAN_LOG_LEVEL=INFO
LOGAN_API_WORKERS=1

# -----------------------------------------------------------------------------
# Security keys. Safe development defaults are built in; production requires
# non-default values of at least 32 characters or the API refuses to start.
# The keyring supports rotation: a JSON map of key id to key material.
# -----------------------------------------------------------------------------
#LOGAN_SECRET_KEY=
#LOGAN_CREDENTIAL_ENCRYPTION_KEY=
#LOGAN_CREDENTIAL_ENCRYPTION_KEY_ID=default
#LOGAN_CREDENTIAL_ENCRYPTION_KEYRING={}

# -----------------------------------------------------------------------------
# LLM provider. `mock` is deterministic and offline for local/CI use;
# `ai_platform` is the only production provider.
# -----------------------------------------------------------------------------
LOGAN_LLM_PROVIDER=mock
LOGAN_AI_PLATFORM_MODEL=gpt-5.4
LOGAN_AI_PLATFORM_REASONING_EFFORT=high
# Chat endpoint. Host is required for real AI Platform calls.
#LOGAN_AI_PLATFORM_CHAT_HOST=
#LOGAN_AI_PLATFORM_CHAT_URI=/v1/api/v1/chat/completions
# Auth option 1: a direct trust token (optionally with a known expiry).
#LOGAN_AI_PLATFORM_TOKEN=
#LOGAN_AI_PLATFORM_TOKEN_EXPIRES_AT=
# Auth option 2: exchange iB2B credentials for a short-lived trust token.
#LOGAN_AI_PLATFORM_USERNAME=
#LOGAN_AI_PLATFORM_PASSWORD=
#LOGAN_AI_PLATFORM_USERCASE=
#LOGAN_AI_PLATFORM_IB2B_HOST=
#LOGAN_AI_PLATFORM_IB2B_URI=/dsp/rest-sts/DSP_iB2B/iB2B_tokenTranslator_v2?_action=translate
# Client behavior.
#LOGAN_AI_PLATFORM_TRUST_TOKEN_HEADER=X-XXXX-E2E-Trust-Token
#LOGAN_AI_PLATFORM_TRACKING_PREFIX=EFP
#LOGAN_AI_PLATFORM_MAX_COMPLETION_TOKENS=4096
#LOGAN_AI_PLATFORM_STORE_COMPLETIONS=false
#LOGAN_AI_PLATFORM_TOKEN_TTL_SECONDS=30
#LOGAN_AI_PLATFORM_TIMEOUT_SECONDS=120
# TLS/proxy. CA bundle falls back to SSL_CERT_FILE or REQUESTS_CA_BUNDLE.
# TLS verification must stay enabled in production.
#LOGAN_AI_PLATFORM_TLS_VERIFY=true
#LOGAN_AI_PLATFORM_CA_BUNDLE=
#LOGAN_AI_PLATFORM_PROXY_URL=
#LOGAN_AI_PLATFORM_TRUST_ENV=true

# -----------------------------------------------------------------------------
# Sign-in. LogAn is SSO-only (username/password auth is removed). Local
# development uses the built-in mock SSO endpoints; production points the
# authorize/token URLs at the corporate identity provider and must keep
# LOGAN_SSO_MOCK_ENABLED=false.
# -----------------------------------------------------------------------------
LOGAN_SSO_ENABLED=true
LOGAN_SSO_MOCK_ENABLED=true
LOGAN_SSO_AUTHORIZE_URL=http://localhost:8000/api/auth/sso/mock/authorize
LOGAN_SSO_TOKEN_URL=http://localhost:8000/api/auth/sso/mock/token
LOGAN_SSO_MOCK_USERNAME=logan.local
LOGAN_SSO_MOCK_EMAIL=logan.local@example.com
LOGAN_SSO_MOCK_FULL_NAME="Logan Local User"
#LOGAN_SSO_CLIENT_ID=webapp
#LOGAN_SSO_AUTHORIZE_SCOPE="read write"
#LOGAN_SSO_TOKEN_SCOPE=offline_access
#LOGAN_SSO_TLS_VERIFY=true
#LOGAN_SSO_TIMEOUT_SECONDS=15

# -----------------------------------------------------------------------------
# Metadata store. `auto` uses SQLAlchemy with the configured database URL;
# `memory` is for explicit ephemeral tests; `sqlalchemy` requires a URL.
# -----------------------------------------------------------------------------
LOGAN_DATABASE_URL=sqlite:///.logan/logan.db
#LOGAN_DATABASE_URL=postgresql+psycopg://logan:logan@localhost:5432/logan
#LOGAN_STORE_BACKEND=auto

# -----------------------------------------------------------------------------
# Object storage for uploaded log bytes. `local` writes under the local
# directory; `s3`/`minio` enable presigned single and multipart uploads.
# -----------------------------------------------------------------------------
LOGAN_OBJECT_STORE_BACKEND=local
#LOGAN_LOCAL_OBJECT_STORE_DIR=.logan/object-store
#LOGAN_ANALYSIS_INPUT_TMP_DIR=.logan/analysis-inputs
#LOGAN_S3_ENDPOINT=http://localhost:9000
#LOGAN_S3_BUCKET=logan
#LOGAN_S3_ACCESS_KEY=logan
#LOGAN_S3_SECRET_KEY=logan-secret
#LOGAN_S3_REGION=us-east-1
#LOGAN_S3_PRESIGN_EXPIRES_SECONDS=900
#LOGAN_S3_FORCE_PATH_STYLE=true
#LOGAN_S3_MULTIPART_THRESHOLD_BYTES=104857600
#LOGAN_S3_MULTIPART_PART_SIZE_BYTES=67108864
#LOGAN_S3_MULTIPART_MAX_PARTS=10000

# -----------------------------------------------------------------------------
# Analysis orchestration. `local` runs synchronously in the API process;
# `temporal` starts AnalyzeCaseWorkflow on the configured Temporal cluster
# and requires a running worker.
# -----------------------------------------------------------------------------
LOGAN_ANALYSIS_ORCHESTRATOR=local
#LOGAN_TEMPORAL_ADDRESS=temporal:7233
#LOGAN_TEMPORAL_NAMESPACE=default
#LOGAN_TEMPORAL_TASK_QUEUE=logan-analysis
#LOGAN_TEMPORAL_ACTIVITY_START_TO_CLOSE_SECONDS=3600
#LOGAN_TEMPORAL_ACTIVITY_MAX_ATTEMPTS=3

# -----------------------------------------------------------------------------
# Step artifacts. One safe count-only step_manifest JSON per completed
# pipeline step. `fail` makes artifact storage errors fail the run.
# -----------------------------------------------------------------------------
#LOGAN_STEP_ARTIFACTS_ENABLED=true
#LOGAN_STEP_ARTIFACT_FAILURE_MODE=warn

# -----------------------------------------------------------------------------
# External analytics sinks and report reads (ClickHouse / OpenSearch).
# Disabled by default: no external network calls. External report queries
# additionally require a succeeded analytics_sink_writes record per run.
# -----------------------------------------------------------------------------
#LOGAN_ANALYTICS_SINKS_ENABLED=false
#LOGAN_ANALYTICS_SINK_FAILURE_MODE=warn
#LOGAN_CLICKHOUSE_URL=http://localhost:8123
#LOGAN_CLICKHOUSE_DATABASE=logan
#LOGAN_CLICKHOUSE_USERNAME=
#LOGAN_CLICKHOUSE_PASSWORD=
#LOGAN_OPENSEARCH_URL=http://localhost:9200
#LOGAN_OPENSEARCH_USERNAME=
#LOGAN_OPENSEARCH_PASSWORD=
#LOGAN_EXTERNAL_ANALYTICS_QUERIES_ENABLED=false
#LOGAN_EXTERNAL_ANALYTICS_QUERY_TIMEOUT_SECONDS=10

# -----------------------------------------------------------------------------
# Retention windows in days. Raw log text is scrubbed in place; report
# retention clears serialized results only when fan-out rows remain.
# -----------------------------------------------------------------------------
#LOGAN_RAW_LOG_RETENTION_DAYS=30
#LOGAN_REPORT_RETENTION_DAYS=365
#LOGAN_AUDIT_RETENTION_DAYS=730

# -----------------------------------------------------------------------------
# API rate limiting.
# -----------------------------------------------------------------------------
#LOGAN_RATE_LIMIT_ENABLED=false
#LOGAN_RATE_LIMIT_REQUESTS_PER_MINUTE=120

# -----------------------------------------------------------------------------
# Observability. Prometheus metrics are on by default; OpenTelemetry
# tracing is optional and off by default.
# -----------------------------------------------------------------------------
#LOGAN_METRICS_ENABLED=true
#LOGAN_METRICS_PATH=/metrics
#LOGAN_OTEL_ENABLED=false
#LOGAN_OTEL_SERVICE_NAME=logan-api
#LOGAN_OTEL_EXPORTER_OTLP_ENDPOINT=

# -----------------------------------------------------------------------------
# SCIM provisioning. Bearer-token SCIM traffic is scoped to one organization.
# -----------------------------------------------------------------------------
#LOGAN_SCIM_BEARER_TOKEN=
#LOGAN_SCIM_ORGANIZATION_ID=default

# -----------------------------------------------------------------------------
# Browser-facing URLs.
# -----------------------------------------------------------------------------
LOGAN_CORS_ALLOWED_ORIGINS=http://localhost:3000
LOGAN_WEB_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Docker Compose helpers (interpolation-only; not read by the API process).
# LOGAN_COMPOSE_DATABASE_URL keeps the compose stack on PostgreSQL even when
# .env carries the local SQLite LOGAN_DATABASE_URL.
# -----------------------------------------------------------------------------
#LOGAN_COMPOSE_DATABASE_URL=postgresql+psycopg://logan:logan@postgres:5432/logan
#LOGAN_WEB_PORT=3000
#LOGAN_API_PORT=8000
#LOGAN_POSTGRES_PORT=5432
#LOGAN_REDIS_PORT=6379
#LOGAN_MINIO_PORT=9000
#LOGAN_MINIO_CONSOLE_PORT=9001
#LOGAN_CLICKHOUSE_PORT=8123
#LOGAN_CLICKHOUSE_NATIVE_PORT=9002
#LOGAN_OPENSEARCH_PORT=9200
#LOGAN_TEMPORAL_PORT=7233

# -----------------------------------------------------------------------------
# Full-stack smoke helpers, used only by scripts/full_stack_smoke.py and
# tests/integration/test_full_stack_smoke.py.
# -----------------------------------------------------------------------------
#LOGAN_RUN_FULL_STACK_SMOKE=false
#LOGAN_FULL_STACK_API_BASE_URL=http://localhost:8000
#LOGAN_FULL_STACK_DATABASE_URL=postgresql+psycopg://logan:logan@localhost:5432/logan
#LOGAN_FULL_STACK_S3_ENDPOINT=http://localhost:9000
#LOGAN_FULL_STACK_S3_PUBLIC_ENDPOINT=http://localhost:9000
#LOGAN_FULL_STACK_CLICKHOUSE_URL=http://localhost:8123
#LOGAN_FULL_STACK_OPENSEARCH_URL=http://localhost:9200
